{
  "name": "hacker-rank-in-js",
  "version": "1.0.0",
  "description": "Hacker Rank’s Tests in JS",
  "main": "index.js",
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:debug": "bun --inspect test --runInBand",
    "test:debug:watch": "bun --inspect test --watch --runInBand",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "author": "Gustavo Saiani ",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "^1.1.14",
    "husky": "^9.1.7",
    "typescript": "^5.7.2"
  }
}
